# --- EchoMood Production Environment Variables ---

# 1. Frontend Environment Variables
# The URL where the browser can reach the backend Flask API.
# Note: In Vite, variables must be prefixed with 'VITE_' to be loaded in client code.
VITE_API_BASE_URL=http://localhost:5000

# 2. Backend Environment Variables
# The MongoDB connection string (e.g., MongoDB Atlas, local container, etc.)
# If left empty, the backend will automatically fallback to Mongita local disk storage.
MONGO_URI=mongodb://mongodb:27017/echomood_db

# The port the backend server should run on
PORT=5000
